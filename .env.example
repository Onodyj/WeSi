# SiteIQ Environment Configuration
# Copy this file to .env and fill in your values

# --- Database ---
# SQLite (default, no setup needed):
DATABASE_URL=sqlite:///siteiq.db
# PostgreSQL example:
# DATABASE_URL=******localhost/siteiq

# --- Security ---
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Required for encrypted API key storage. Leave unset for dev mode (plaintext, not secure).
WESI_ENCRYPTION_KEY=

# --- Flask ---
FLASK_SECRET_KEY=change-me-in-production
FLASK_DEBUG=false

# --- Async Processing (optional — thread-based fallback used by default) ---
# Set USE_CELERY=true and provide REDIS_URL to enable Celery/Redis
USE_CELERY=false
REDIS_URL=redis://localhost:6379/0

# --- AI Providers (all optional — rule-based suggestions used when not configured) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
# Ollama (local): set base URL if running Ollama locally
OLLAMA_BASE_URL=http://localhost:11434
# N8N webhook URL for AI
N8N_WEBHOOK_URL=

# --- Authority & Backlinks Providers (all optional) ---
OPEN_PAGERANK_API_KEY=
# MOZ_ACCESS_ID=
# MOZ_SECRET_KEY=
# MAJESTIC_API_KEY=
# DATAFORSEO_LOGIN=
# DATAFORSEO_PASSWORD=

# --- Analysis Defaults ---
MAX_PAGES_DEFAULT=50
MAX_DEPTH_DEFAULT=3
