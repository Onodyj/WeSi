# WeSi API Configuration
# Copy this file to .env and configure as needed

# Database path (optional, defaults to data/wesi.db)
# WESI_DB_PATH=/path/to/custom/wesi.db

# API Server settings
# WESI_HOST=0.0.0.0
# WESI_PORT=8000

# Client settings for example_api_usage.py
# WESI_API_KEY=your-api-key-here
# WESI_API_URL=http://localhost:8000
