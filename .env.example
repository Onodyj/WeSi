# WeSi Environment Configuration
# Copy this file to .env and fill in your values

# Flask Configuration
FLASK_SECRET_KEY=your-flask-secret-key-change-in-production
FLASK_DEBUG=false
DATABASE_URL=sqlite:///wesi.db

# Encryption Key for API Keys
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
WESI_ENCRYPTION_KEY=your-fernet-encryption-key-here

# Redis Configuration (for Celery)
REDIS_URL=redis://localhost:6379/0

# Optional: Server-side OpenAI API Key
# If not provided, users must supply their own keys
OPENAI_API_KEY=sk-your-openai-api-key

# Optional: Google Docs API Credentials
# Path to service account JSON file
GOOGLE_DOCS_CREDENTIALS=/path/to/service-account-credentials.json

# Optional: Playwright for JS rendering
# Set to 'true' to enable JavaScript rendering
ENABLE_PLAYWRIGHT=false
# WeSi API Configuration
# Copy this file to .env and configure as needed

# Database path (optional, defaults to data/wesi.db)
# WESI_DB_PATH=/path/to/custom/wesi.db

# API Server settings
# WESI_HOST=0.0.0.0
# WESI_PORT=8000

# Client settings for example_api_usage.py
# WESI_API_KEY=your-api-key-here
# WESI_API_URL=http://localhost:8000
