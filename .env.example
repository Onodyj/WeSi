# SiteIQ Environment Configuration
# Copy this file to .env and fill in your values

# --- Database ---
# SQLite (default, no setup needed):
DATABASE_URL=sqlite:///siteiq.db
# PostgreSQL example:
# DATABASE_URL=******localhost/siteiq

# --- Security ---
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Required for encrypted API key storage. Leave unset for dev mode (plaintext, not secure).
WESI_ENCRYPTION_KEY=

# --- Flask ---
FLASK_SECRET_KEY=change-me-in-production
FLASK_DEBUG=false

# --- Async Processing (optional — thread-based fallback used by default) ---
# Set USE_CELERY=true and provide REDIS_URL to enable Celery/Redis
USE_CELERY=false
REDIS_URL=redis://localhost:6379/0

# --- AI Providers (all optional — rule-based suggestions used when not configured) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
# Ollama (local): set base URL if running Ollama locally
OLLAMA_BASE_URL=http://localhost:11434
# N8N webhook URL for AI
N8N_WEBHOOK_URL=

# --- Authority & Backlinks Providers (all optional) ---
OPEN_PAGERANK_API_KEY=
# MOZ_ACCESS_ID=
# MOZ_SECRET_KEY=
# MAJESTIC_API_KEY=
# DATAFORSEO_LOGIN=
# DATAFORSEO_PASSWORD=

# --- Analysis Defaults ---
MAX_PAGES_DEFAULT=50
MAX_DEPTH_DEFAULT=3
# WeSi Environment Configuration
# Copy this file to .env and fill in your values

# Flask Configuration
FLASK_SECRET_KEY=your-flask-secret-key-change-in-production
FLASK_DEBUG=false
DATABASE_URL=sqlite:///wesi.db

# Encryption Key for API Keys
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
WESI_ENCRYPTION_KEY=your-fernet-encryption-key-here

# Redis Configuration (for Celery)
REDIS_URL=redis://localhost:6379/0

# Optional: Server-side OpenAI API Key
# If not provided, users must supply their own keys
OPENAI_API_KEY=sk-your-openai-api-key

# Optional: Google Docs API Credentials
# Path to service account JSON file
GOOGLE_DOCS_CREDENTIALS=/path/to/service-account-credentials.json

# Optional: Playwright for JS rendering
# Set to 'true' to enable JavaScript rendering
ENABLE_PLAYWRIGHT=false
# WeSi API Configuration
# Copy this file to .env and configure as needed

# Database path (optional, defaults to data/wesi.db)
# WESI_DB_PATH=/path/to/custom/wesi.db

# API Server settings
# WESI_HOST=0.0.0.0
# WESI_PORT=8000

# Client settings for example_api_usage.py
# WESI_API_KEY=your-api-key-here
# WESI_API_URL=http://localhost:8000
