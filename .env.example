# WeSi Environment Configuration
# Copy this file to .env and fill in your values

# Flask Configuration
FLASK_SECRET_KEY=your-flask-secret-key-change-in-production
DATABASE_URL=sqlite:///wesi.db

# Encryption Key for API Keys
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
WESI_ENCRYPTION_KEY=your-fernet-encryption-key-here

# Redis Configuration (for Celery)
REDIS_URL=redis://localhost:6379/0

# Optional: Server-side OpenAI API Key
# If not provided, users must supply their own keys
OPENAI_API_KEY=sk-your-openai-api-key

# Optional: Google Docs API Credentials
# Path to service account JSON file
GOOGLE_DOCS_CREDENTIALS=/path/to/service-account-credentials.json

# Optional: Playwright for JS rendering
# Set to 'true' to enable JavaScript rendering
ENABLE_PLAYWRIGHT=false
